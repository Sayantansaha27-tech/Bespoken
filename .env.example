# ─────────────────────────────────────────────────────────────────────────────
# Bespoken — environment variables
# Copy this file to .env and fill in the values before running docker compose.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
DB_USER=bespoken
DB_PASSWORD=change_me_strong_password

# Host port to expose Postgres on (optional, useful for local inspection)
DB_PORT_EXPOSE=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PORT_EXPOSE=6379

# ── JWT Secrets (generate with: openssl rand -hex 64) ────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars

# Token lifetimes (seconds)
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=1209600

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the API Gateway
CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:3300

# ── Cookies ───────────────────────────────────────────────────────────────────
# Set to true in production (requires HTTPS)
COOKIE_SECURE=false
COOKIE_DOMAIN=

# ── Frontend (Vite build-time) ────────────────────────────────────────────────
# Public URL of the API Gateway — baked into the frontend bundle at build time
VITE_API_BASE_URL=http://localhost:3300
